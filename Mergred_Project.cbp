void renderDaySceneR() {
    glClearColor(0.53f, 0.81f, 0.98f, 1.0f);
    glClear(GL_COLOR_BUFFER_BIT);
    glColor3f(0.53f, 0.81f, 0.98f);
    sky();
    sun();
    cloud1();
    cloud2();
    cloud3();
}



void renderNightSceneR() {
   glColor3f(0.05f, 0.05f, 0.25f);
   glClear(GL_COLOR_BUFFER_BIT);

    sky();
    star();
    moon();
    moon2();

}


void displayh() {
    //glClear(GL_COLOR_BUFFER_BIT);
    glLoadIdentity();

    if (isDayR) {
        renderDaySceneR();
    } else {
        renderNightSceneR();
    }
    tree3();
    grassfield();
    road();
    grassfield2();
    building1();
    building2();
    mosque();
    foodcourt();
    tree();
    tree2();
    tree4();

    car1();
    car2();

    glutSwapBuffers();
}





void update(int value) {




     // move carR right -> left
    _move1 -= speed1;                        //ANM2
    if (_move1 < -180.0f) {
        _move1 = 180.0f;
    }



    _move2 += speed2;                        //ANM3
    if (_move2 > 180.0f) {
        _move2 = -180.0f;
    }


   _movecloud1 += _speedcloud1;
   if (_movecloud1 > 200.0f) {
    _movecloud1 = -160.0f;

   }

   _movecloud2 += _speedcloud2;
    if (_movecloud2 > 200.0f) {
    _movecloud2 = -210.0f;   // bit later
    }

    _movecloud3 += _speedcloud3;
    if (_movecloud3 > 200.0f) {
    _movecloud3 = -260.0f;  //  last
    }




    glutPostRedisplay();
    glutTimerFunc(10, update, 0);
}





void update1(int value) {
    // rotate wheels
    angle1 -= 5.0f;
    if (angle1 < -360.0f) angle1 += 360.0f;



     angle2 -= 5.0f;
    if (angle2 < -360.0f) angle2 += 360.0f;


    glutPostRedisplay();
    glutTimerFunc(10, update1, 0);
}








void handleMouseR(int button, int state, int x, int y) {
    if (button == GLUT_LEFT_BUTTON)
    {
        speed1 += 0.1f;
        speed2 += 0.1f;


    }


    if (button == GLUT_RIGHT_BUTTON)
    {
        speed1 -= 0.1f;
        speed2 -= 0.1f;




        // Ensure minimum speed is reasonable
        if (speed1 < 0.1f) speed1 = 0.1f;
        if (speed2 < 0.1f) speed2 = 0.1f;


    }
    glutPostRedisplay();
}










void handleKeypressR(unsigned char key, int x, int y) {
    switch (key)
    {
        case 's':
            speed1 = 0.0f;
            speed2 = 0.0f;

            break;


        case 'r':
            speed1 = 0.5f;
            speed2 = 0.5f;

            break;


        case 'n':
            isDayR = false;
            break;


        case 'd':
            isDayR = true;
            break;

    }

    glutPostRedisplay();
}








int main(int argc, char** argv) {
    glutInit(&argc, argv);
    glutInitDisplayMode(GLUT_DOUBLE | GLUT_RGB);
    glutInitWindowSize(800, 500);
    glutCreateWindow("Project");
    glMatrixMode(GL_PROJECTION);
    gluOrtho2D(20, 180, 10, 110);
    glMatrixMode(GL_MODELVIEW);

    glutDisplayFunc(displayh);
    glutTimerFunc(20, update, 0);
    glutTimerFunc(20, update1, 0);
    glutKeyboardFunc(handleKeypressR);
    glutMouseFunc(handleMouseR);
    glutMainLoop();
    return 0;
}

