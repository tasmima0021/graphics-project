void car2() {
    glPushMatrix();

    // move right/left with _move1 and go 2 units up
    glTranslatef(_move2, 2.0f, 0.0f);

    glColor3f(0.000f, 0.467f, 0.745f);

    glBegin(GL_QUADS);
        glVertex2f(126.0f, 35.5f);  // 86 + 40
        glVertex2f(126.0f, 30.2f);  // 86 + 40
        glVertex2f(100.0f, 30.2f);  // 60 + 40
        glVertex2f(100.0f, 35.5f);  // 60 + 40
    glEnd();

    glColor3f(0.000f, 0.467f, 0.745f);
    glBegin(GL_QUADS);
        glVertex2f(118.5f, 39.4f);  // 78.5 + 40
        glVertex2f(122.0f, 35.5f);  // 82 + 40
        glVertex2f(103.0f, 35.5f);  // 63 + 40
        glVertex2f(106.0f, 39.4f);  // 66 + 40
    glEnd();

    glColor3f(0.847f, 0.894f, 0.914f);
    glBegin(GL_QUADS);
        glVertex2f(118.2f, 38.9f);  // 78.2 + 40
        glVertex2f(121.0f, 35.5f);  // 81 + 40
        glVertex2f(113.0f, 35.5f);  // 73 + 40
        glVertex2f(113.0f, 38.9f);  // 73 + 40
    glEnd();

    glColor3f(0.847f, 0.894f, 0.914f);
    glBegin(GL_QUADS);
        glVertex2f(112.5f, 38.9f);  // 72.5 + 40
        glVertex2f(112.5f, 35.5f);  // 72.5 + 40
        glVertex2f(104.7f, 35.5f);  // 64.7 + 40
        glVertex2f(106.4f, 38.9f);  // 66.4 + 40
    glEnd();

    glPushMatrix();
        glTranslatef(120.0f, 30.5748862832272f, 0.0f); // 80 + 40
        glRotatef(angle1, 0.0f, 0.0f, 1.0f);
        glColor3f(0.0f, 0.0f, 0.0f);
        drawCircle(0.0f, 0.0f, 2.2f, 100);
    glPopMatrix();

    glPushMatrix();
        glTranslatef(105.8306730447055f, 30.6416901282634f, 0.0f); // 65.83... + 40
        glRotatef(angle1, 0.0f, 0.0f, 1.0f);
        glColor3f(0.0f, 0.0f, 0.0f);
        drawCircle(0.0f, 0.0f, 2.2f, 100);
    glPopMatrix();

    glPopMatrix();
}







